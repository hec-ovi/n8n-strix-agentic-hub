# === INSTANCE ===
GENERIC_TIMEZONE=America/Argentina/Cordoba
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678/
REPORT_SERVICE_PORT=18100
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
REPORT_REQUEST_WEBHOOK_PATH=report-request-v2
TELEGRAM_WEBHOOK_PATH=telegram-report-bot

# === SECURITY ===
N8N_ENCRYPTION_KEY=replace-with-a-long-random-string
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace-with-a-password

# === DATABASE ===
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-a-password
POSTGRES_DB=n8n

# === EXECUTION ===
N8N_WORKER_CONCURRENCY=5
EXECUTIONS_DATA_MAX_AGE_HOURS=168
EXECUTIONS_DATA_PRUNE_MAX_COUNT=10000

# === HOST PATHS ===
N8N_DATA_DIR=/home/hector/workspace/n8n-strix-agentic-hub/.local/n8n
POSTGRES_DATA_DIR=/home/hector/workspace/n8n-strix-agentic-hub/.local/postgres
REDIS_DATA_DIR=/home/hector/workspace/n8n-strix-agentic-hub/.local/redis
REPORT_ARTIFACTS_DIR=/home/hector/workspace/n8n-strix-agentic-hub/.local/report-artifacts
OLLAMA_MODELS_DIR=/home/hector/models/ollama

# === OLLAMA ===
OLLAMA_PORT=11434
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_CONTEXT_LENGTH=8192
OLLAMA_KEEP_ALIVE=5m

# === REPORT SERVICE ===
APP_NAME="n8n Strix Report Service"
API_PREFIX=/api/v1
PUBLIC_BASE_URL=http://localhost:18100
LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=gpt-oss:20b
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=180

# Local default: Mailpit
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SENDER=reports@n8n-strix.local
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURITY=none

# Google Workspace SMTP relay example:
# SMTP_HOST=smtp-relay.gmail.com
# SMTP_PORT=587
# SMTP_SECURITY=starttls
#
# Gmail SMTP example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your.name@example.com
# SMTP_PASSWORD=your-16-digit-app-password
